{
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "includeFiles": "scoring/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" }
  ],
  "redirects": [
    { "source": "/", "destination": "/web/container.html", "permanent": false }
  ]
}
